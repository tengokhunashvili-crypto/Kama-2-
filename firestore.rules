rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "tengo.khunashvili@gmail.com" && request.auth.token.email_verified == true);
    }

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: products
    // Fields: image, category_en, category_ka, en, ka, order, createdAt
    
    // Collection: faqs
    // Fields: en, ka, order

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidProduct(data) {
      return data.keys().hasAll(['image', 'category_en', 'category_ka', 'en', 'ka']) &&
             data.image is string && data.image.size() < 2000 &&
             data.category_en is string && data.category_en.size() < 100 &&
             data.category_ka is string && data.category_ka.size() < 100 &&
             data.en is map && data.ka is map;
    }

    function isValidFAQ(data) {
      return data.keys().hasAll(['en', 'ka']) &&
             data.en is map && data.ka is map;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /products/{productId} {
      allow read: if true; // Publicly readable
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /faqs/{faqId} {
      allow read: if true; // Publicly readable
      allow create: if isAdmin() && isValidFAQ(request.resource.data);
      allow update: if isAdmin() && isValidFAQ(request.resource.data);
      allow delete: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
